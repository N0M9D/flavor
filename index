function applyModeCopy(mode){
  const c=COPY[mode];
  document.getElementById('intro-title').textContent=c.introTitle;
  document.getElementById('intro-sub').textContent=c.introSub;
  ['q1','q2','q3','q4'].forEach(q=>{
    const te=document.getElementById(q+'-text'); if(te) te.textContent=c[q+'Text'];
    const he=document.getElementById(q+'-hint'); if(he) he.textContent=c[q+'Hint']||'';
  });
  [1,2,3].forEach(q=>{
    c['q'+q+'Opts'].forEach((o,i)=>{
      document.getElementById('q'+q+'-o'+(i+1)+'-l').textContent=o.l;
      document.getElementById('q'+q+'-o'+(i+1)+'-s').textContent=o.s;
    });
  });
  document.querySelectorAll('.gift-pill').forEach(el=>el.classList.toggle('show',mode==='gift'));
}

function setMode(mode){
  giftMode=(mode==='gift');
  document.getElementById('nav-btn-personal').classList.toggle('active',!giftMode);
  document.getElementById('nav-btn-gift').classList.toggle('active',giftMode);
  document.getElementById('tab-personal').classList.toggle('active',!giftMode);
  document.getElementById('tab-gift').classList.toggle('active',giftMode);
  applyModeCopy(mode);
}

function disableNavModeToggle(){
  document.getElementById('nav-btn-personal').disabled=true;
  document.getElementById('nav-btn-gift').disabled=true;
}
function enableNavModeToggle(){
  document.getElementById('nav-btn-personal').disabled=false;
  document.getElementById('nav-btn-gift').disabled=false;
}

function show(id){
  ['screen-intro','screen-quiz','screen-brewing','screen-result'].forEach(s=>{
    const el=document.getElementById(s);
    if(!el) return;
    if(s===id){
      // brewing needs flex, others block
      el.style.display = (s==='screen-brewing') ? 'flex' : 'block';
      if(s==='screen-brewing') el.classList.add('show');
    } else {
      el.style.display='none';
      if(s==='screen-brewing') el.classList.remove('show');
    }
  });
  if(id==='screen-result') disableNavModeToggle();
  else enableNavModeToggle();
}

function setProgress(step){
  for(let i=1;i<=4;i++){
    const d=document.getElementById('pd'+i);
    if(!d) continue;
    d.classList.remove('active','done');
    if(i<step) d.classList.add('done');
    else if(i===step) d.classList.add('active');
    const l=document.getElementById('pl'+i);
    if(l) l.classList.toggle('done',i<step);
  }
}
function startQuiz(){show('screen-quiz');setProgress(1);}

/* Option click + SVG swap */
document.querySelectorAll('.opt').forEach(btn=>{
  btn.addEventListener('click',function(){
    const q=this.dataset.q;
    document.querySelectorAll('[data-q="'+q+'"]').forEach(b=>b.classList.remove('selected'));
    this.classList.add('selected');
    A[q]=this.dataset.v;
    document.getElementById('b'+q).removeAttribute('disabled');
    const key=this.dataset.illo;
    const svgEl=document.getElementById('svg-q'+q);
    if(svgEl&&ILLOS[key]){
      svgEl.innerHTML=ILLOS[key];
    }
  });
});

function advance(step){
  if(!A[step]) return;
  const cur=document.getElementById('s'+step),nxt=document.getElementById('s'+(step+1));
  cur.classList.remove('live','back');cur.style.display='none';
  setTimeout(()=>{nxt.style.display='flex';nxt.classList.remove('back');nxt.classList.add('live');setProgress(step+1);},20);
}
function goBack(step){
  const cur=document.getElementById('s'+(step+1)),prev=document.getElementById('s'+step);
  cur.classList.remove('live','back');cur.style.display='none';
  setTimeout(()=>{prev.style.display='flex';prev.classList.remove('live');prev.classList.add('back');setProgress(step);},20);
}

/* Intensity gauge. fixed arc math */
const slider=document.getElementById('intensity-slider');
const slabels=['','Gentle','Gentle','Light','Balanced','Balanced','Medium','Medium','Bold','Bold','Intense'];

function updateGauge(v){
  // Fill segments 1..v with active colour, rest go back to grey
  document.querySelectorAll('.iseg').forEach(seg => {
    const n = parseInt(seg.dataset.seg);
    seg.classList.toggle('active', n <= v);
  });
}

slider.addEventListener('input',function(){
  const v=parseInt(this.value);A.intensity=v;
  const pct=((v-1)/9)*100;
  this.style.background=`linear-gradient(to right,var(--amber) 0%,var(--amber) ${pct}%,var(--cream-3) ${pct}%,var(--cream-3) 100%)`;
  document.getElementById('slider-display').textContent=slabels[v];
  document.getElementById('slider-sub').textContent='· intensity '+v+' of 10';
  updateGauge(v);
});
updateGauge(5);

function score(s,a1,a2,a3,intensity){
  return (s.time.includes(a1)?3:0)+(s.mood.includes(a2)?3:0)+(s.act.includes(a3)?3:0)+Math.max(0,2-Math.abs(s.intNum-intensity)*0.4);
}

function brewAndReveal(){
  show('screen-brewing');setProgress(5);
  const total=BREW_STEPS.length*STEP_DURATION;
  const fill=document.getElementById('brew-fill');let h=0;
  const fi=setInterval(()=>{h+=0.22;if(h>=28){clearInterval(fi);h=28;}fill.setAttribute('height',h.toFixed(2));fill.setAttribute('y',(78-h).toFixed(2));},total/(28/0.22));
  const bar=document.getElementById('brew-bar');
  bar.style.transition='width '+total+'ms cubic-bezier(.4,0,.6,1)';
  setTimeout(()=>{bar.style.width='100%';},40);
  const ce=document.getElementById('brew-copy'),he=document.getElementById('brew-hint');
  const timers=[];
  for(let i=1;i<BREW_STEPS.length;i++){
    timers.push(setTimeout(()=>{
      ce.classList.add('fade');he.classList.add('fade');
      setTimeout(()=>{ce.textContent=BREW_STEPS[i].copy;he.textContent=BREW_STEPS[i].hint;ce.classList.remove('fade');he.classList.remove('fade');},FADE_DURATION);
    },i*STEP_DURATION));
  }
  setTimeout(()=>{timers.forEach(t=>clearTimeout(t));showResult();},total+200);
}

