}

function toggleNote(el){const wo=el.classList.contains('open');document.querySelectorAll('.result-note').forEach(n=>n.classList.remove('open'));if(!wo)el.classList.add('open');}
function selectPack(btn){document.querySelectorAll('.pack-opt').forEach(b=>b.classList.remove('active'));btn.classList.add('active');currentPack=parseInt(btn.dataset.pack);document.getElementById('rlink').href=currentSKU[PACK_KEYS[currentPack]];updateStickyCart();}

function shareResult(){
  const params=new URLSearchParams({t:A[1]||'',m:A[2]||'',a:A[3]||'',i:A.intensity||5,sku:currentSKU.name});
  const url=window.location.href.split('?')[0]+'?'+params;
  navigator.clipboard.writeText(url).then(()=>{
    const btn=document.getElementById('share-btn');
    btn.innerHTML='✓ Copied!';btn.classList.add('copied');
    setTimeout(()=>{btn.innerHTML='<svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M12 3a1 1 0 1 0 0 2 1 1 0 0 0 0-2zM9.5 4.5l-3 1.8M6.5 9.7l3 1.8M11 7a1 1 0 1 1 0 2 1 1 0 0 1 0-2zM12 11a1 1 0 1 0 0 2 1 1 0 0 0 0-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> Share result';btn.classList.remove('copied');},2500);
  }).catch(()=>prompt('Copy this link:',url));
}

function shareToInstagram(){
  /* Instagram doesn't support direct URL sharing from web.
     Best approach: copy the share URL + open Instagram */
  if(currentSKU){
    const td=getCoffeeTitle(A[1],A[2],A[3]);
    const text=`I'm ${td.title} ☕\nMy Elevens match: ${currentSKU.name}\nFind yours → elevens.coffee #ElevensCoffee #FindYourElevens`;
