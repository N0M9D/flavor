<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flavour Finder. Elevens Coffee</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Playfair+Display:ital,wght@0,600;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --cream:#F5F0E8;--cream-2:#EDE5D8;--cream-3:#E0D5C4;
  --ink:#1A1208;--ink-2:#3D2E18;--ink-3:#7A6040;
  --amber:#C8860A;--amber-l:#F0C060;--amber-xl:#FEF6E4;
  --white:#FFFDF8;
  --s1:#F9F4EC;--s2:#F7F1E8;--s3:#F5EEE3;--s4:#F3EBDD;
}
html,body{min-height:100%;background:var(--cream);font-family:'DM Sans',sans-serif;color:var(--ink);-webkit-font-smoothing:antialiased;position:relative}

/* ── COFFEE BEAN BG PATTERN ── */
.bg-pattern{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;opacity:.06}
.bg-pattern svg{position:absolute}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(245,240,232,.96);backdrop-filter:blur(8px);border-bottom:1px solid var(--cream-3);display:flex;align-items:center;justify-content:space-between;padding:0 1.75rem;height:60px}
.nav-left{display:flex;align-items:center;gap:10px}
.nav-divider{width:1px;height:18px;background:var(--cream-3)}
.nav-logo img{height:28px;display:block}
.nav-logo-fallback{display:none;font-size:15px;font-weight:600;color:var(--ink)}
.nav-right{display:flex;align-items:center;gap:10px}
.nav-mode-toggle{display:flex;align-items:center;background:var(--cream-2);border-radius:100px;padding:3px;gap:2px;border:1px solid var(--cream-3)}
.nav-mode-btn{font-size:12px;font-weight:500;color:var(--ink-3);background:none;border:none;border-radius:100px;padding:5px 14px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;white-space:nowrap}
.nav-mode-btn.active{background:var(--white);color:var(--ink);box-shadow:0 1px 4px rgba(26,18,8,.1)}
.nav-mode-btn:disabled{opacity:.4;cursor:not-allowed}
.nav-tag{font-size:12px;font-weight:500;color:var(--ink-3);letter-spacing:.05em;background:var(--cream-2);border:1px solid var(--cream-3);border-radius:100px;padding:5px 12px}

/* ── PAGE ── */
.page{min-height:100vh;padding:80px 0 3rem;display:flex;align-items:center;justify-content:center;position:relative;z-index:1}
.card{background:var(--white);border-radius:20px;box-shadow:0 4px 24px rgba(26,18,8,.08),0 32px 80px rgba(26,18,8,.12);width:100%;max-width:680px;margin:0 1.25rem;overflow:hidden}

/* ── INTRO ── */
#screen-intro{
  background:var(--s1);
  padding:3rem 2rem 2.75rem;
  text-align:center;
}
.intro-inner{
  max-width:400px;
  margin:0 auto;
  display:flex;
  flex-direction:column;
  align-items:center;
}
.intro-illo{margin:0 0 1.5rem}
.intro-title{font-size:28px;font-weight:600;color:var(--ink);line-height:1.2;margin:0 0 .75rem}
.intro-sub{font-size:15px;font-weight:300;color:var(--ink-3);line-height:1.7;margin:0 0 1.75rem}
.intro-mode-tabs{display:flex;gap:10px;margin:0 0 2rem;width:100%}
.intro-tab{flex:1;padding:14px 16px;border-radius:14px;border:2px solid var(--cream-3);background:var(--white);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s cubic-bezier(.34,1.56,.64,1);text-align:center}
.intro-tab:hover{border-color:var(--amber-l);transform:translateY(-1px)}
.intro-tab.active{border-color:var(--amber);background:var(--amber-xl)}
.intro-tab-icon{font-size:20px;display:block;margin:0 0 5px}
.intro-tab-label{font-size:14px;font-weight:500;color:var(--ink);display:block}
.intro-tab-sub{font-size:11px;font-weight:300;color:var(--ink-3);display:block;margin-top:2px}
.intro-tab.active .intro-tab-sub{color:var(--amber)}
.btn-start{display:inline-flex;align-items:center;gap:8px;background:var(--ink);color:var(--cream);font-family:'DM Sans',sans-serif;font-size:16px;font-weight:500;border:none;border-radius:100px;padding:15px 40px;cursor:pointer;transition:background .2s,transform .2s cubic-bezier(.34,1.56,.64,1),box-shadow .2s;box-shadow:0 4px 16px rgba(26,18,8,.2)}
.btn-start:hover{background:var(--ink-2);transform:translateY(-2px);box-shadow:0 8px 24px rgba(26,18,8,.25)}

/* ── PROGRESS ── */
#screen-quiz{display:none}
/* Step dots progress */
.quiz-progress-dots{display:flex;align-items:center;justify-content:center;gap:0;padding:.875rem 1.5rem;background:var(--white);border-bottom:1px solid var(--cream-2)}
.prog-dot-wrap{display:flex;align-items:center}
.prog-dot{width:28px;height:28px;border-radius:50%;border:2px solid var(--cream-3);background:var(--white);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;color:var(--ink-3);transition:all .3s cubic-bezier(.34,1.56,.64,1);flex-shrink:0;position:relative}
.prog-dot.active{border-color:var(--amber);background:var(--amber);color:var(--white);transform:scale(1.15)}
.prog-dot.done{border-color:var(--amber);background:var(--amber-xl);color:var(--amber)}
.prog-dot.done::after{content:'✓';position:absolute;font-size:11px;font-weight:600;color:var(--amber)}
.prog-dot.done span{display:none}
.prog-line{width:28px;height:2px;background:var(--cream-3);transition:background .3s ease;flex-shrink:0}
.prog-line.done{background:var(--amber)}
.prog-dot-lbl{font-size:10px;color:var(--ink-3);position:absolute;top:32px;left:50%;transform:translateX(-50%);white-space:nowrap;font-weight:400;transition:color .3s}
.prog-dot.active .prog-dot-lbl{color:var(--amber);font-weight:500}
.prog-dot-wrap{position:relative;padding-bottom:20px}

/* ── STEP. illustration above, 2×2 options ── */
.step{display:none;flex-direction:column;padding:1.75rem 2rem 1.5rem;transition:background .4s ease}
.step.live{display:flex;animation:stepIn .35s cubic-bezier(.22,1,.36,1)}
.step.back{display:flex;animation:stepBack .35s cubic-bezier(.22,1,.36,1)}
@keyframes stepIn  {from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}
@keyframes stepBack{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:translateX(0)}}

.step-topbar{display:flex;align-items:center;justify-content:space-between;margin:0 0 1rem}
.step-back-btn{background:none;border:none;cursor:pointer;padding:0;color:var(--ink-3);font-size:13px;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:4px;transition:color .15s}
.step-back-btn:hover{color:var(--ink)}
.gift-pill{display:none;font-size:10px;font-weight:500;color:var(--amber);background:var(--amber-xl);border-radius:100px;padding:3px 9px}
.gift-pill.show{display:inline-block}

/* Illustration row. centered above options */
.step-illo-row{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.75rem;margin:0 0 1.25rem}
.step-illo-wrap{display:flex;align-items:center;justify-content:center;animation:float 4s ease-in-out infinite;flex-shrink:0}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
.step-copy{text-align:center;width:100%}
.step-q{font-size:20px;font-weight:600;color:var(--ink);line-height:1.3;margin:0 0 .3rem}
.step-hint{font-size:12px;font-weight:300;color:var(--ink-3);line-height:1.5}

/* 2×2 options grid */
.opts{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.opt{display:flex;align-items:center;gap:10px;padding:11px 13px;background:var(--cream);border:2px solid var(--cream-2);border-radius:14px;cursor:pointer;text-align:left;width:100%;font-family:'DM Sans',sans-serif;transition:all .2s cubic-bezier(.34,1.56,.64,1);position:relative;overflow:hidden}
.opt::before{content:'';position:absolute;inset:0;background:var(--amber-xl);opacity:0;transition:opacity .2s}
.opt:hover{border-color:var(--amber-l);transform:translateY(-1px);box-shadow:0 3px 10px rgba(200,134,10,.1)}
.opt:hover::before{opacity:1}
.opt.selected{border-color:var(--amber);background:var(--amber-xl);transform:translateY(-1px);box-shadow:0 3px 14px rgba(200,134,10,.18)}
.opt:focus-visible{outline:none;box-shadow:0 0 0 3px rgba(200,134,10,.35)}

.opt-body{flex:1;position:relative;z-index:1;min-width:0}
.opt-label{font-size:13px;font-weight:500;color:var(--ink);display:block;line-height:1.3}
.opt-sub{font-size:11px;font-weight:300;color:var(--ink-3);display:block;margin-top:1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.opt-check{width:18px;height:18px;border-radius:50%;border:2px solid var(--cream-3);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .25s cubic-bezier(.34,1.56,.64,1);position:relative;z-index:1}
.opt.selected .opt-check{background:var(--amber);border-color:var(--amber);transform:scale(1.1)}
.opt-check svg{opacity:0;transform:scale(0);transition:all .2s cubic-bezier(.34,1.56,.64,1)}
.opt.selected .opt-check svg{opacity:1;transform:scale(1)}

.step-foot{margin-top:1rem;display:flex;justify-content:center}
.btn-next{display:inline-flex;align-items:center;gap:8px;background:var(--ink);color:var(--cream);font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;border:none;border-radius:100px;padding:12px 32px;cursor:pointer;transition:all .2s cubic-bezier(.34,1.56,.64,1);box-shadow:0 3px 12px rgba(26,18,8,.18)}
.btn-next:disabled{background:var(--cream-3);color:var(--ink-3);cursor:not-allowed;box-shadow:none;transform:none}
.btn-next:not(:disabled):hover{background:var(--ink-2);transform:translateY(-1px);box-shadow:0 6px 18px rgba(26,18,8,.22)}
.btn-next:focus-visible{outline:none;box-shadow:0 0 0 3px rgba(26,18,8,.25)}

/* ── INTENSITY STEP ── */
.step.intensity-step{padding:1.75rem 2.5rem 1.75rem}
.intensity-header{display:flex;align-items:center;justify-content:space-between;margin:0 0 1rem}
.intensity-content{display:flex;flex-direction:column;align-items:center;gap:1.25rem}
.intensity-copy{text-align:center}
.intensity-copy .step-q{font-size:19px;margin:0 0 .25rem}
.intensity-copy .step-hint{font-size:12px}
.gauge-wrap{display:none}
/* Intensity segment bar */
.intensity-bar-wrap{width:100%;max-width:420px;margin:0 auto .5rem}
.intensity-segments{
  display:flex;gap:5px;align-items:flex-end;
  height:56px;margin:0 0 .5rem;
}
.iseg{
  flex:1;border-radius:5px 5px 3px 3px;
  background:var(--cream-3);
  transition:background .25s ease, height .3s cubic-bezier(.34,1.56,.64,1);
  min-height:8px;
}
/* Height gradient: taller as intensity increases */
.iseg[data-seg="1"] {height:18%}
.iseg[data-seg="2"] {height:26%}
.iseg[data-seg="3"] {height:34%}
.iseg[data-seg="4"] {height:44%}
.iseg[data-seg="5"] {height:54%}
.iseg[data-seg="6"] {height:63%}
.iseg[data-seg="7"] {height:72%}
.iseg[data-seg="8"] {height:81%}
.iseg[data-seg="9"] {height:90%}
.iseg[data-seg="10"]{height:100%}
.iseg.active{background:var(--amber)}
.iseg.active:nth-child(-n+3){background:#F0C060}
.iseg.active:nth-child(n+4):nth-child(-n+6){background:#D4960A}
.iseg.active:nth-child(n+7):nth-child(-n+8){background:#C8860A}
.iseg.active:nth-child(n+9){background:#A06808}
.intensity-bar-labels{
  display:flex;justify-content:space-between;
  font-size:11px;color:var(--ink-3);
}
.slider-scene{width:100%;max-width:420px}
.slider-labels{display:flex;justify-content:space-between;margin:0 0 .5rem}
.slider-lbl{font-size:12px;color:var(--ink-3)}
input[type=range].intensity-slider{width:100%;-webkit-appearance:none;appearance:none;height:6px;border-radius:3px;background:linear-gradient(to right,var(--amber) 0%,var(--amber) 44%,var(--cream-3) 44%,var(--cream-3) 100%);outline:none;cursor:pointer;margin:0 0 .75rem}
input[type=range].intensity-slider::-webkit-slider-thumb{-webkit-appearance:none;width:26px;height:26px;border-radius:50%;background:var(--ink);border:3px solid var(--white);box-shadow:0 2px 8px rgba(26,18,8,.25);cursor:pointer;transition:transform .18s cubic-bezier(.34,1.56,.64,1)}
input[type=range].intensity-slider::-webkit-slider-thumb:hover{transform:scale(1.15)}
.slider-value-row{display:flex;align-items:baseline;justify-content:center;gap:.5rem}
.slider-value-big{font-size:22px;font-weight:600;color:var(--ink)}
.slider-value-sub{font-size:13px;font-weight:300;color:var(--ink-3)}
.intensity-foot{margin-top:1.25rem;display:flex;align-items:center;justify-content:center;gap:14px}
.intensity-back{font-size:13px;color:var(--ink-3);background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;padding:0;transition:color .15s}
.intensity-back:hover{color:var(--ink)}

/* ── BREWING ── */
#screen-brewing{display:none;min-height:380px;flex-direction:column;align-items:center;justify-content:center;padding:3rem 2.5rem;text-align:center;background:var(--s4)}
#screen-brewing.show{display:flex}
.brew-illo{margin:0 auto 1.75rem}
.brew-main{font-size:22px;font-weight:600;color:var(--ink);margin:0 0 .5rem;min-height:32px;transition:opacity .55s ease;text-align:center;width:100%}
.brew-main.fade{opacity:0}
.brew-sub{font-size:14px;font-weight:300;color:var(--ink-3);margin:0 0 2rem;min-height:22px;line-height:1.6;max-width:300px;text-align:center;transition:opacity .55s ease;align-self:center}
.brew-sub.fade{opacity:0}
.brew-track{width:260px;height:4px;background:var(--cream-3);border-radius:2px;overflow:hidden;margin:0 auto}
.brew-fill-bar{height:100%;width:0%;background:var(--amber);border-radius:2px}

/* ── RESULT ── */
#screen-result{display:none}

/* ── RESULT SCREEN ── */

/* Personality label — dark background, light text */
.coffee-title-screen{
  background:var(--ink);          /* default; overridden per-SKU by JS */
  padding:2rem 2rem 1.75rem;
  text-align:center;
  position:relative;
  overflow:hidden;
}

/* Subtle top-left arc — clean, structural, not gradient */
.coffee-title-screen::before{
  content:'';position:absolute;
  top:-48px;left:-48px;
  width:160px;height:160px;
  border-radius:50%;
  border:1px solid rgba(255,255,255,.07);
  pointer-events:none;
}
.coffee-title-screen::after{
  content:'';position:absolute;
  bottom:-32px;right:-32px;
  width:100px;height:100px;
  border-radius:50%;
  border:1px solid rgba(255,255,255,.05);
  pointer-events:none;
}

.ct-eyebrow{
  font-size:10px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;
  color:rgba(255,255,255,.5);margin:0 0 .75rem;
}

.ct-title-wrap{
  filter:blur(14px);opacity:0;transform:scale(.96);
  transition:filter 1.3s cubic-bezier(.22,1,.36,1) .3s,
             opacity 1s ease .3s,
             transform .85s cubic-bezier(.22,1,.36,1) .3s;
  margin:0 0 .65rem;
  display:flex;flex-direction:column;align-items:center;gap:.6rem;
}
.ct-title-wrap.revealed{filter:blur(0);opacity:1;transform:scale(1)}

/* Face portrait ring */
.ct-face-wrap{
  width:76px;height:76px;border-radius:50%;overflow:hidden;
  border:3px solid rgba(255,255,255,.2);
  box-shadow:0 0 0 1px rgba(255,255,255,.08), 0 4px 16px rgba(0,0,0,.25);
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,.08);
  flex-shrink:0;
}
.ct-face-wrap svg{display:block}

.ct-title-text{
  font-family:'Playfair Display',serif;
  font-size:26px;font-weight:600;
  color:#fff;
  line-height:1.15;display:block;
  letter-spacing:-.01em;
}

.ct-desc{
  font-size:14px;font-weight:300;
  color:rgba(255,255,255,.65);
  max-width:360px;margin:0 auto .875rem;line-height:1.75;
  filter:blur(6px);opacity:0;
  transition:filter .9s ease .9s,opacity .8s ease .9s;
}
.ct-desc.revealed{filter:blur(0);opacity:1}

.ct-insta-wrap{
  opacity:0;transform:translateY(4px);
  transition:opacity .5s ease 1.4s,transform .45s cubic-bezier(.22,1,.36,1) 1.4s;
}
.ct-insta-wrap.revealed{opacity:1;transform:translateY(0)}

.ct-insta-btn{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.18);
  border-radius:100px;padding:6px 14px;
  font-family:'DM Sans',sans-serif;font-size:11px;font-weight:500;
  color:rgba(255,255,255,.65);cursor:pointer;transition:all .2s;
}
.ct-insta-btn:hover{
  background:rgba(255,255,255,.16);
  border-color:rgba(255,255,255,.35);
  color:#fff;
}

.result-divider{height:1px;background:var(--cream-2);margin:1rem 0}

/* Product block. two-col with WHITE image bg */
.result-top{display:flex;align-items:stretch;min-height:200px}
.result-img-col{
  width:185px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  padding:1.5rem 1rem;
  background:#ffffff !important; /* always white regardless of SKU */
}
.result-hero-img{
  max-width:140px;max-height:175px;
  width:auto;height:auto;object-fit:contain;
  opacity:0;transform:translateY(8px) scale(.96);
  transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1);
}
.result-hero-img.loaded{opacity:1;transform:translateY(0) scale(1)}
.result-name-col{
  flex:1;
  padding:1.5rem 1.5rem 1.5rem 1.25rem;
  display:flex;flex-direction:column;justify-content:center;
  position:relative;overflow:hidden;
  transition:background .6s ease;
}
.result-name-col::after{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;border:1px solid rgba(255,255,255,.12)}
.result-kicker{font-size:10px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.5);margin:0 0 .35rem}
.result-name{
  font-family:'Playfair Display',serif;
  font-size:24px;font-weight:600;
  color:#fff;line-height:1.1;margin:0 0 .3rem;
  position:relative;z-index:1;
}
.result-meta-inline{display:flex;flex-wrap:wrap;gap:5px;position:relative;z-index:1}
.meta-pill{background:rgba(255,255,255,.1);border-radius:6px;padding:4px 8px}
.meta-pill-lbl{font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.38);display:block}
.meta-pill-val{font-size:12px;font-weight:500;color:rgba(255,255,255,.85);display:block;margin-top:1px}

/* Result body */
.result-body{padding:1.5rem 1.5rem 1.75rem;background:var(--white)}
.result-notes{display:flex;flex-wrap:wrap;gap:6px;margin:0 0 1rem}
.result-note{font-size:12px;font-weight:500;color:var(--ink-2);border-radius:100px;padding:4px 12px;cursor:pointer;border:1px solid transparent;transition:all .15s;animation:popIn .4s cubic-bezier(.34,1.56,.64,1) both;position:relative}
.result-note:hover{opacity:.85}
.result-note.open{color:#fff}
@keyframes popIn{from{opacity:0;transform:scale(.6)}to{opacity:1;transform:scale(1)}}
.note-tooltip{display:none;position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:#1A1208;color:#FAF7F2;font-size:12px;font-weight:300;line-height:1.5;padding:8px 14px;border-radius:10px;width:200px;text-align:center;z-index:50;opacity:1;pointer-events:none;box-shadow:0 4px 16px rgba(0,0,0,.25)}
.note-tooltip::after{content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:var(--ink)}
.result-note.open .note-tooltip{display:block}
.brew-tip{display:flex;align-items:flex-start;gap:10px;background:var(--amber-xl);border-radius:12px;padding:.75rem 1rem;margin:0 0 1rem}
.brew-tip-icon{font-size:15px;flex-shrink:0;margin-top:1px}
.brew-tip-text{font-size:13px;color:var(--ink-2);line-height:1.6}
.brew-tip-text strong{font-weight:500}
.result-reason{font-size:13px;color:var(--ink-2);line-height:1.8;padding:.875rem 1.1rem;background:var(--cream);border-radius:10px;margin:0 0 1rem}
.review-block{border-left:3px solid var(--amber-l);padding:.7rem 1rem;margin:0 0 1rem;background:var(--white)}
.review-q{font-size:13px;font-style:italic;color:var(--ink-2);line-height:1.65;display:block;margin:0 0 .35rem}
.review-attr{font-size:11px;color:var(--ink-3);font-weight:500;display:block}
.pack-section{margin:0 0 1rem}
.pack-label{font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);margin:0 0 .5rem;display:block}
.pack-options{display:flex;gap:8px}
.pack-opt{flex:1;padding:9px 6px;border:2px solid var(--cream-3);border-radius:10px;background:var(--white);cursor:pointer;text-align:center;font-family:'DM Sans',sans-serif;transition:all .2s cubic-bezier(.34,1.56,.64,1)}
.pack-opt:hover{border-color:var(--amber-l);background:var(--amber-xl);transform:translateY(-1px)}
.pack-opt.active{border-color:var(--amber);background:var(--amber-xl);transform:translateY(-1px);box-shadow:0 3px 10px rgba(200,134,10,.15)}
.pack-opt-count{font-size:15px;font-weight:600;color:var(--ink);display:block}
.pack-opt-pods{font-size:10px;color:var(--ink-3);display:block;margin-top:1px}
.pack-opt-price{font-size:11px;font-weight:500;color:var(--amber);display:block;margin-top:2px}
.result-ctas{display:flex;gap:8px;flex-wrap:wrap;margin:0 0 1rem}
.btn-shop{flex:1;display:inline-flex;align-items:center;justify-content:center;gap:7px;color:var(--white);font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;text-decoration:none;border-radius:100px;padding:12px 22px;border:none;cursor:pointer;transition:all .2s cubic-bezier(.34,1.56,.64,1);box-shadow:0 3px 12px rgba(0,0,0,.2)}
.btn-shop:hover{opacity:.9;transform:translateY(-1px)}
.btn-share{display:inline-flex;align-items:center;justify-content:center;gap:6px;background:var(--white);color:var(--ink);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;border-radius:100px;border:2px solid var(--cream-3);padding:11px 18px;cursor:pointer;transition:all .18s}
.btn-share:hover{border-color:var(--amber);color:var(--amber);transform:translateY(-1px)}
.btn-share.copied{border-color:var(--amber);color:var(--amber);background:var(--amber-xl)}
.alt-section{border-top:1px solid var(--cream-2);padding:1rem 0 0;margin:0 0 1rem}
.alt-label{font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);margin:0 0 2px;display:block}
.alt-sublabel{font-size:12px;color:var(--ink-3);font-weight:300;margin:0 0 .6rem}
.sub-nudge{background:var(--cream);border:1px solid var(--cream-2);border-radius:12px;padding:.875rem 1rem;margin:1rem 0}
.sub-nudge-inner{display:flex;align-items:center;gap:10px}
.sub-nudge-icon{font-size:18px;flex-shrink:0}
.sub-nudge-body{flex:1;min-width:0}
.sub-nudge-title{font-size:13px;font-weight:500;color:var(--ink);margin:0 0 2px}
.sub-nudge-sub{font-size:12px;color:var(--ink-3);font-weight:300;margin:0}
.sub-nudge-link{font-size:12px;font-weight:500;color:var(--amber);white-space:nowrap;text-decoration:none;flex-shrink:0}
.sub-nudge-link:hover{text-decoration:underline}
.alt-card{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--cream);border-radius:12px;border:2px solid var(--cream-2);cursor:pointer;transition:all .18s;text-decoration:none}
.alt-card:hover{border-color:var(--amber-l);background:var(--amber-xl);transform:translateY(-1px)}
.alt-img{width:44px;height:44px;object-fit:contain;border-radius:8px;background:var(--cream-2);flex-shrink:0}
.alt-body{flex:1;min-width:0}
.alt-name{font-size:13px;font-weight:500;color:var(--ink);display:block;margin:0 0 1px}
.alt-reason{font-size:11px;color:var(--ink-3);font-weight:300;line-height:1.4;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.alt-arrow{color:var(--ink-3);font-size:18px;flex-shrink:0}
.email-section{border-top:1px solid var(--cream-2);padding:1rem 0 0;margin:0 0 .75rem}
.email-label{font-size:13px;font-weight:500;color:var(--ink);margin:0 0 .2rem}
.email-sub{font-size:11px;color:var(--ink-3);font-weight:300;margin:0 0 .6rem}
.email-form{display:flex;gap:8px}
.email-input{flex:1;padding:10px 14px;border:2px solid var(--cream-3);border-radius:100px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--ink);background:var(--white);outline:none;transition:border-color .18s}
.email-input:focus{border-color:var(--amber)}
.email-input::placeholder{color:var(--ink-3)}
.btn-email{padding:10px 18px;background:var(--ink);color:var(--cream);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;border:none;border-radius:100px;cursor:pointer;transition:background .18s;white-space:nowrap}
.btn-email:hover{background:var(--ink-2)}
.email-success{display:none;font-size:12px;color:var(--amber);font-weight:500;padding:.4rem 0}
.btn-restart{display:block;background:none;border:none;font-family:'DM Sans',sans-serif;font-size:12px;color:var(--ink-3);cursor:pointer;padding:4px 0;transition:color .15s}
.btn-restart:hover{color:var(--ink)}
.result-entry{animation:resultIn .55s cubic-bezier(.22,1,.36,1)}
@keyframes resultIn{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.steam-path{stroke-dasharray:32;stroke-dashoffset:32;animation:steamUp 2.4s ease-in-out infinite}
.steam-path:nth-child(2){animation-delay:.5s}
.steam-path:nth-child(3){animation-delay:1s}
@keyframes steamUp{0%{stroke-dashoffset:32;opacity:0}15%{opacity:.75}100%{stroke-dashoffset:-32;opacity:0}}

/* ── STICKY CART BAR ── */
.sticky-cart{position:fixed;bottom:0;left:0;right:0;z-index:200;background:var(--white);border-top:1px solid var(--cream-2);padding:.75rem 1.25rem;display:none;align-items:center;justify-content:space-between;gap:12px;box-shadow:0 -4px 20px rgba(26,18,8,.1)}
.sticky-cart.visible{display:flex;animation:slideUp .3s cubic-bezier(.22,1,.36,1)}
