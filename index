    <span class="sticky-cart-price">1 pack · <strong id="sticky-price">₹504</strong> &nbsp;&middot;&nbsp; ~₹46/cup</span>
  </div>
  <button class="sticky-cart-btn" id="sticky-btn" onclick="stickyShop()">Add to cart →</button>
</div>
