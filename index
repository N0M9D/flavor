.sticky-cart-btn{display:inline-flex;align-items:center;gap:7px;color:var(--white);font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;border:none;border-radius:100px;padding:12px 24px;cursor:pointer;white-space:nowrap;flex-shrink:0;transition:opacity .15s,transform .15s}
.sticky-cart-btn:hover{opacity:.9;transform:translateY(-1px)}
/* Pack value + trust */
.pack-opt-cpp{font-size:10px;color:var(--ink-3);display:block;margin-top:1px;font-weight:300}
.pack-value-line{font-size:12px;color:var(--ink-3);font-weight:300;margin:.5rem 0 .875rem;text-align:center}
.trust-row{display:flex;gap:8px;flex-wrap:wrap;margin:.5rem 0 1.25rem;justify-content:center}
.trust-chip{font-size:11px;color:var(--ink-3);background:var(--cream);border:1px solid var(--cream-2);border-radius:100px;padding:4px 10px;font-weight:400}
/* Origin badge */
.result-origin{font-size:11px;font-weight:300;color:rgba(255,255,255,.4);margin:0 0 .8rem;position:relative;z-index:1;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.origin-badge{display:inline-flex;align-items:center;gap:4px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);border-radius:100px;padding:3px 9px;font-size:10px;font-weight:500;letter-spacing:.04em;color:rgba(255,255,255,.85)}
/* Gift block */
.gift-result-block{background:var(--amber-xl);border:1px solid var(--amber-l);border-radius:12px;padding:1rem 1.1rem;margin:0 0 1rem}
.gift-result-inner{display:flex;align-items:center;gap:12px}
.gift-result-icon{font-size:22px;flex-shrink:0}
.gift-result-body{flex:1;min-width:0}
.gift-result-title{font-size:13px;font-weight:500;color:var(--ink);margin:0 0 2px}
.gift-result-sub{font-size:12px;font-weight:300;color:var(--ink-3);margin:0;line-height:1.5}
.gift-result-btn{flex-shrink:0;display:inline-flex;align-items:center;background:var(--amber);color:var(--white);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;border-radius:100px;padding:7px 14px;text-decoration:none;white-space:nowrap;transition:opacity .15s}
.gift-result-btn:hover{opacity:.88}
</style>
</head>
