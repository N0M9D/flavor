}

function submitEmail(){
  const val=document.getElementById('email-input').value.trim();
  if(!val||!val.includes('@')){document.getElementById('email-input').focus();return;}
  document.getElementById('email-form').style.display='none';
  document.getElementById('email-success').style.display='block';
}

function restart(){
  A[1]=null;A[2]=null;A[3]=null;A.intensity=5;
  currentSKU=null;currentAlt=null;currentPack=1;
  document.querySelectorAll('.opt').forEach(b=>b.classList.remove('selected'));
  document.querySelectorAll('.btn-next').forEach(b=>b.setAttribute('disabled',''));
  document.getElementById('b4').removeAttribute('disabled');
  document.querySelectorAll('.step').forEach(s=>{s.style.display='none';s.classList.remove('live','back');});
  document.getElementById('brew-fill').setAttribute('height','0');document.getElementById('brew-fill').setAttribute('y','78');
  const bar=document.getElementById('brew-bar');bar.style.transition='none';bar.style.width='0%';
  document.getElementById('brew-copy').textContent=BREW_STEPS[0].copy;
  document.getElementById('brew-hint').textContent=BREW_STEPS[0].hint;
  document.getElementById('screen-brewing').classList.remove('show');
  slider.value=5;A.intensity=5;
  slider.style.background='linear-gradient(to right,var(--amber) 0%,var(--amber) 44%,var(--cream-3) 44%,var(--cream-3) 100%)';
  document.getElementById('slider-display').textContent='Balanced';
  document.getElementById('slider-sub').textContent='· intensity 5 of 10';
  updateGauge(5);
  setProgress(1); // reset dots
  document.getElementById('result-img').classList.remove('loaded');document.getElementById('result-img').src='';
  document.getElementById('ct-badge').classList.remove('revealed');
  document.getElementById('ct-desc').classList.remove('revealed');
  document.getElementById('ct-insta-wrap').classList.remove('revealed');
  const s1=document.getElementById('s1');s1.style.display='flex';s1.classList.add('live');
  show('screen-quiz');
  enableNavModeToggle();
  const sc=document.getElementById('sticky-cart');if(sc)sc.classList.remove('visible');
}


/* ── STICKY CART ── */
let _stickyObserver=null;
function updateStickyCart(){
  if(!currentSKU) return;
  /* sticky updated via updateStickyCart() call below */
}
function stickyShop(){
  if(currentSKU) window.open(currentSKU[PACK_KEYS[currentPack]],'_blank','noopener');
}
function setupStickyObserver(){
  const bar=document.getElementById('sticky-cart');
  const sentinel=document.getElementById('result-img-col');
  if(!bar||!sentinel) return;
  if(_stickyObserver) _stickyObserver.disconnect();
  _stickyObserver=new IntersectionObserver(entries=>{
    if(entries[0].isIntersecting){bar.classList.remove('visible');}
    else if(currentSKU){bar.classList.add('visible');}
  },{threshold:0});
  _stickyObserver.observe(sentinel);
}

(function(){
  const params=new URLSearchParams(window.location.search);
  if(params.get('sku')){const t=params.get('t'),m=params.get('m'),a=params.get('a'),i=parseInt(params.get('i'))||5;if(t&&m&&a){A[1]=t;A[2]=m;A[3]=a;A.intensity=i;showResult();return;}}
  show('screen-intro');
})();
</script>
