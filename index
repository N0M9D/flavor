.sticky-cart-left{flex:1;min-width:0}
.sticky-cart-name{font-size:14px;font-weight:600;color:var(--ink);display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sticky-cart-price{font-size:13px;color:var(--ink-3);display:block;margin-top:1px}
